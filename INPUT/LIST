<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    
<ul class="list-group container mt-3">
    <H1>BASIC LIST</H1>
  <li class="list-group-item">First item</li>
  <li class="list-group-item">Second item</li>
  <li class="list-group-item">Third item</li>
</ul>
<hr>
<div class="container mt-3">
  <h2>Active Item in a List Group</h2>
  <ul class="list-group">
    <li class="list-group-item active">Active item</li>
    <li class="list-group-item">Second item</li>
    <li class="list-group-item">Third item</li>
  </ul></div>
   <hr>
  <div class="list-group container mt-3"> <h1>List Group With Linked Items</h1>
  <a href="#" class="list-group-item list-group-item-action">First item</a>
  <a href="#" class="list-group-item list-group-item-action">Second item</a>
  <a href="#" class="list-group-item list-group-item-action">Third item</a>
</div> <hr>
<div class="list-group container mt-3">
    <h1>Disabled Item</h1>
  <a href="#" class="list-group-item disabled">removed item</a>
  <a href="#" class="list-group-item disabled">removed item</a>
  <a href="#" class="list-group-item">unremoved item</a>
</div><hr>
<ol class="list-group list-group-numbered container mt-3">
    <H1>Numbered List Groups</H1>
  <li class="list-group-item">APPLE</li>
  <li class="list-group-item">ORANGE</li>
  <li class="list-group-item">JACKFRUIT</li>
</ol><hr>
<ul class="list-group list-group-horizontal container mt-3">
    <h1>Horizontal List Groups</h1><br>
 <br>
 <li class="list-group-item">Home</li>
  <li class="list-group-item">About</li>
  <li class="list-group-item">Your Order</li>
  <li class="list-group-item">Contact Us</li>
</ul> <hr>
</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
